{
  "version": 2,
  "buildCommand": "npm install && npx prisma generate && npm run build",
  "outputDirectory": "dist",
  "functions": {
    "dist/main.js": {
      "runtime": "@vercel/node@3",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/dist/main.js"
    }
  ]
}
