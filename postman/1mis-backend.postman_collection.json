{
  "info": {
    "name": "1mis Backend API",
    "_postman_id": "d2b5e826-8fb8-4d24-90c0-1mis-backend-api",
    "description": "Postman collection for 1mis.io backend APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "storeId",
      "value": ""
    },
    {
      "key": "jobId",
      "value": ""
    },
    {
      "key": "ownerEmail",
      "value": "henryowner+{{$timestamp}}@example.com"
    },
    {
      "key": "ownerPassword",
      "value": "123456"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Auth - Signup (Owner)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Henry Owner\",\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/signup"
      }
    },
    {
      "name": "Auth - Login (Super Admin)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.accessToken) pm.collectionVariables.set('accessToken', jsonData.accessToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@1mis.io\",\n  \"password\": \"admin12345\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/api/auth/me"
      }
    },
    {
      "name": "Stores - Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.id) pm.collectionVariables.set('storeId', jsonData.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"1mis Demo Store\",\n  \"slug\": \"demo-store-{{ownerEmail}}\",\n  \"themePreset\": \"aurora\"\n}"
        },
        "url": "{{baseUrl}}/api/stores"
      }
    },
    {
      "name": "AI - Generate",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.id) pm.collectionVariables.set('jobId', jsonData.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"prompt\": \"Build a premium ecommerce store for headphones\",\n  \"inputImages\": []\n}"
        },
        "url": "{{baseUrl}}/api/stores/{{storeId}}/ai/generate"
      }
    },
    {
      "name": "AI - Job Result",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/api/stores/{{storeId}}/ai/jobs/{{jobId}}/result"
      }
    },
    {
      "name": "Super Admin - Health",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/api/super-admin/health"
      }
    },
    {
      "name": "Super Admin - Patch Lifecycle",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"publishStatus\": \"published\",\n  \"domainStatus\": \"connected\",\n  \"sslStatus\": \"active\"\n}"
        },
        "url": "{{baseUrl}}/api/super-admin/lifecycle/{{storeId}}"
      }
    },
    {
      "name": "Super Admin - Patch Payment Ops",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"stripeEnabled\": true,\n  \"sslCommerzEnabled\": true,\n  \"codEnabled\": false,\n  \"mode\": \"live\"\n}"
        },
        "url": "{{baseUrl}}/api/super-admin/payment-ops/{{storeId}}"
      }
    },
    {
      "name": "Super Admin - Patch Ticket",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"in_progress\",\n  \"priority\": \"high\",\n  \"note\": \"Investigating checkout failure\"\n}"
        },
        "url": "{{baseUrl}}/api/super-admin/tickets/T-1001"
      }
    },
    {
      "name": "Super Admin - PUT Settings Batch",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"values\": {\n    \"platform.ui\": {\"theme\": \"light\"},\n    \"platform.notify\": {\"email\": \"ops@1mis.io\"}\n  }\n}"
        },
        "url": "{{baseUrl}}/api/super-admin/settings"
      }
    },
    {
      "name": "Remaining APIs (Owner + SuperAdmin)",
      "item": [
        {
          "name": "Owner - Dashboard Overview",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/stores/{{storeId}}/dashboard/overview"
          }
        },
        {
          "name": "Owner - Shipping Config (Methods + Charges + Rates)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"methods\": {\n    \"standard\": true,\n    \"express\": true,\n    \"pickup\": true,\n    \"cod\": true\n  },\n  \"charges\": {\n    \"flatCharge\": 60,\n    \"expressCharge\": 120\n  },\n  \"rates\": [\n    { \"name\": \"Inside Dhaka\", \"country\": \"BD\", \"amount\": 60 },\n    { \"name\": \"Outside Dhaka\", \"country\": \"BD\", \"amount\": 120 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/stores/{{storeId}}/shipping/config"
          }
        },
        {
          "name": "Owner - Shipping Orders (Merged Delivery View)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/stores/{{storeId}}/shipping/orders?page=1&limit=20&q=&status=completed&sort=createdAt_desc"
          }
        },
        {
          "name": "Owner - Product Delivery Toggle",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enabled\": true\n}"
            },
            "url": "{{baseUrl}}/api/stores/{{storeId}}/products/{{productId}}/delivery"
          }
        },
        {
          "name": "Owner - AI Section Apply (Dry Run)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"section\": \"hero\",\n  \"prompt\": \"Make hero headline premium and modern\",\n  \"dryRun\": true\n}"
            },
            "url": "{{baseUrl}}/api/stores/{{storeId}}/ai/sections/apply"
          }
        },
        {
          "name": "Owner - AI Section Apply (Persist)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.historyId) pm.collectionVariables.set('sectionHistoryId', jsonData.historyId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"section\": \"hero\",\n  \"prompt\": \"Set hero title to \\\"Launch Fast\\\"\",\n  \"dryRun\": false\n}"
            },
            "url": "{{baseUrl}}/api/stores/{{storeId}}/ai/sections/apply"
          }
        },
        {
          "name": "Owner - AI Section History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/stores/{{storeId}}/ai/sections/history"
          }
        },
        {
          "name": "Owner - AI Section History Revert",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Undo latest section update\"\n}"
            },
            "url": "{{baseUrl}}/api/stores/{{storeId}}/ai/sections/history/{{sectionHistoryId}}/revert"
          }
        },
        {
          "name": "Owner - Update User Profile (name/businessName/email)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
